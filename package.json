{
  "name": "tecniya",
  "version": "1.0.0",
  "description": "Plataforma de Soporte Técnico a Domicilio con Triage por IA Local",
  "private": true,
  "scripts": {
    "dev:backend": "npm run start:dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "migration:run": "npm run migration:run --prefix backend",
    "migration:generate": "npm run migration:generate --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
